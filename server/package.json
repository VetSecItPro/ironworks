{
  "name": "@ironworksai/server",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/ironworksai/ironworks",
  "bugs": {
    "url": "https://github.com/ironworksai/ironworks/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ironworksai/ironworks",
    "directory": "server"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "cross-env IRONWORKS_MIGRATION_PROMPT=never IRONWORKS_MIGRATION_AUTO_APPLY=true tsx ./scripts/dev-watch.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc && mkdir -p dist/onboarding-assets && cp -R src/onboarding-assets/. dist/onboarding-assets/",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @ironworksai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@ironworksai/adapter-anthropic-api": "workspace:*",
    "@ironworksai/adapter-claude-local": "workspace:*",
    "@ironworksai/adapter-codex-local": "workspace:*",
    "@ironworksai/adapter-cursor-local": "workspace:*",
    "@ironworksai/adapter-gemini-local": "workspace:*",
    "@ironworksai/adapter-openclaw-gateway": "workspace:*",
    "@ironworksai/adapter-openai-api": "workspace:*",
    "@ironworksai/adapter-opencode-local": "workspace:*",
    "@ironworksai/adapter-openrouter-api": "workspace:*",
    "@ironworksai/adapter-pi-local": "workspace:*",
    "@ironworksai/adapter-poe-api": "workspace:*",
    "@ironworksai/adapter-utils": "workspace:*",
    "@ironworksai/db": "workspace:*",
    "@ironworksai/plugin-sdk": "workspace:*",
    "@ironworksai/shared": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.4.18",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "dompurify": "^3.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "embedded-postgres": "18.1.0-beta.16",
    "express": "^5.2.1",
    "hermes-paperclip-adapter": "0.1.1",
    "jsdom": "^29.0.2",
    "multer": "^2.1.1",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsdom": "^28.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
