{
  "name": "@ironworksai/ui",
  "version": "0.3.1",
  "description": "Prebuilt Ironworks board UI assets.",
  "license": "MIT",
  "homepage": "https://github.com/ironworksai/ironworks",
  "bugs": {
    "url": "https://github.com/ironworksai/ironworks/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ironworksai/ironworks",
    "directory": "ui"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "rm -f package.dev.json && cp package.json package.dev.json && node ../scripts/generate-ui-package-json.mjs",
    "postpack": "if [ -f package.dev.json ]; then mv package.dev.json package.json; fi"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ironworksai/adapter-claude-local": "workspace:*",
    "@ironworksai/adapter-codex-local": "workspace:*",
    "@ironworksai/adapter-cursor-local": "workspace:*",
    "@ironworksai/adapter-gemini-local": "workspace:*",
    "@ironworksai/adapter-openclaw-gateway": "workspace:*",
    "@ironworksai/adapter-opencode-local": "workspace:*",
    "@ironworksai/adapter-pi-local": "workspace:*",
    "@ironworksai/adapter-utils": "workspace:*",
    "@ironworksai/shared": "workspace:*",
    "@lexical/link": "0.35.0",
    "@mdxeditor/editor": "^3.55.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lexical": "0.35.0",
    "lucide-react": "^0.574.0",
    "mermaid": "^11.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^3.2.4"
  }
}
