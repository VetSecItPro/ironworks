DATABASE_URL=postgres://ironworks:ironworks@localhost:5432/ironworks
PORT=3100
SERVE_UI=false

# Required for Docker deployments
BETTER_AUTH_SECRET=your-auth-secret-here
IRONWORKS_PUBLIC_URL=http://localhost:3100

# Deployment mode: "open" (no auth) or "authenticated" (requires login)
# IRONWORKS_DEPLOYMENT_MODE=authenticated
# IRONWORKS_DEPLOYMENT_EXPOSURE=private

# Heartbeat scheduler (agent polling)
# HEARTBEAT_SCHEDULER_ENABLED=true
# HEARTBEAT_SCHEDULER_INTERVAL_MS=30000

# Database backup (embedded mode)
# IRONWORKS_DB_BACKUP_ENABLED=true
# IRONWORKS_DB_BACKUP_INTERVAL_MINUTES=60
# IRONWORKS_DB_BACKUP_RETENTION_DAYS=30

# For Docker production (docker-compose.production.yml)
# POSTGRES_PASSWORD=your-postgres-password

# LLM Provider API keys (set the ones you use)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# OLLAMA_API_KEY=your-ollama-cloud-key
# OLLAMA_BASE_URL=http://localhost:11434

# Polar billing (optional)
# POLAR_ACCESS_TOKEN=your-polar-token
# POLAR_WEBHOOK_SECRET=whsec_...
# POLAR_ORGANIZATION_ID=your-org-id

# Agent JWT (for external agent authentication)
# IRONWORKS_AGENT_JWT_SECRET=your-jwt-secret
# IRONWORKS_AGENT_JWT_ISSUER=ironworks
# IRONWORKS_AGENT_JWT_AUDIENCE=ironworks-agents
