{
  "name": "@ironworksai/db",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/ironworksai/ironworks",
  "bugs": {
    "url": "https://github.com/ironworksai/ironworks/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ironworksai/ironworks",
    "directory": "packages/db"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp -r src/migrations dist/migrations",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "generate": "tsc -p tsconfig.json && drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@ironworksai/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "embedded-postgres": "18.1.0-beta.16",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
