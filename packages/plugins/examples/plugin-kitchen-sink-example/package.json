{
  "name": "@ironworksai/plugin-kitchen-sink-example",
  "version": "0.1.0",
  "description": "Reference plugin that demonstrates the full Ironworks plugin surface area in one package",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "ironworksPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @ironworksai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@ironworksai/plugin-sdk": "workspace:*",
    "@ironworksai/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
