{
  "name": "@ironworksai/plugin-authoring-smoke-example",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "A Ironworks plugin",
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "ironworks-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @ironworksai/plugin-sdk build && tsc --noEmit"
  },
  "ironworksPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "ironworks",
    "plugin",
    "connector"
  ],
  "author": "Plugin Author",
  "license": "MIT",
  "dependencies": {
    "@ironworksai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
"typescript": "^6.0.3",
        "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
